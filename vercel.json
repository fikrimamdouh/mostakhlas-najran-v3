{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/mustaklassat run build && pnpm --filter @workspace/db run push-force",
  "outputDirectory": "artifacts/mustaklassat/dist/public",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
