{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/mustaklassat run build",
  "outputDirectory": "artifacts/mustaklassat/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api-mostakhlas.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
