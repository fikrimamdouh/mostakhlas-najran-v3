# اترك VITE_API_BASE_URL فارغًا ليستخدم التطبيق /api على نفس الدومين.
# حتى لو وُجدت قيمة VITE_API_BASE_URL قديمة في Vercel فلن تُستخدم إلا إذا فعّلت VITE_ALLOW_EXTERNAL_API.
VITE_API_BASE_URL=
VITE_ALLOW_EXTERNAL_API=false

# في التطوير، Vite يمرر /api إلى API_PROXY_TARGET لتجنب مشاكل CORS في المتصفح.
API_PROXY_TARGET=https://api-mostakhlas.vercel.app

# استخدم pk_test محليًا فقط، و pk_live في Vercel/production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
