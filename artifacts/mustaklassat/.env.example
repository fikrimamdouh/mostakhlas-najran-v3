# Frontend API: اتركه فارغًا ليستخدم التطبيق /api على نفس الدومين.
VITE_API_BASE_URL=
VITE_ALLOW_EXTERNAL_API=false

# Dev-only API proxy target for Vite. لا يُستخدم في production build.
API_PROXY_TARGET=https://api-mostakhlas.vercel.app

# Clerk frontend key. استخدم pk_test محليًا فقط، و pk_live في Vercel/production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Alias مدعوم لو كانت إعدادات Vercel/Next تستخدم NEXT_PUBLIC_*.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Production-only backend/server env vars (set in Vercel, do not expose the secret in the browser).
# CLERK_SECRET_KEY=sk_live_xxx
# CLERK_PUBLISHABLE_KEY=pk_live_xxx
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Custom domain/CORS. ضع الدومين المخصص الحقيقي بدل example.
APP_ORIGIN=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com
